<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.attendance.mapper.OvertimeRequestMapper">

    <resultMap id="overtimeRequestMap" type="com.attendance.entity.OvertimeRequest">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="overtimeDate" column="overtime_date"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="hours" column="hours"/>
        <result property="reason" column="reason"/>
        <result property="status" column="status"/>
        <result property="rejectReason" column="reject_reason"/>
        <result property="approverId" column="approver_id"/>
        <result property="approveTime" column="approve_time"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <insert id="insert" parameterType="com.attendance.entity.OvertimeRequest" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_overtime_request (user_id, overtime_date, start_time, end_time, hours, reason, status, create_time, update_time)
        VALUES (#{userId}, #{overtimeDate}, #{startTime}, #{endTime}, #{hours}, #{reason}, 0, NOW(), NOW())
    </insert>

    <update id="updateById" parameterType="com.attendance.entity.OvertimeRequest">
        UPDATE t_overtime_request SET
            status = #{status},
            reject_reason = #{rejectReason},
            approver_id = #{approverId},
            approve_time = NOW(),
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <select id="selectById" resultMap="overtimeRequestMap">
        SELECT * FROM t_overtime_request WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="overtimeRequestMap">
        SELECT * FROM t_overtime_request WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>

    <select id="selectPending" resultMap="overtimeRequestMap">
        SELECT * FROM t_overtime_request WHERE status = 0 ORDER BY create_time ASC
    </select>

    <select id="selectAll" resultMap="overtimeRequestMap">
        SELECT * FROM t_overtime_request ORDER BY create_time DESC LIMIT #{offset}, #{limit}
    </select>

    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM t_overtime_request
    </select>

</mapper>
