<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.attendance.mapper.LeaveRequestMapper">

    <resultMap id="BaseResultMap" type="com.attendance.entity.LeaveRequest">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="leave_type" property="leaveType"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="reason" property="reason"/>
        <result column="status" property="status"/>
        <result column="approver_id" property="approverId"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.attendance.entity.LeaveRequest">
        INSERT INTO leave_request 
        (user_id, leave_type, start_time, end_time, reason, status, create_time)
        VALUES 
        (#{userId}, #{leaveType}, #{startTime}, #{endTime}, #{reason}, #{status}, #{createTime})
    </insert>

    <update id="update" parameterType="com.attendance.entity.LeaveRequest">
        UPDATE leave_request
        <set>
            <if test="leaveType != null">leave_type = #{leaveType},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="reason != null">reason = #{reason},</if>
            <if test="status != null">status = #{status},</if>
            <if test="approverId != null">approver_id = #{approverId},</if>
        </set>
        WHERE id = #{id}
    </update>

    <select id="selectById" parameterType="Integer" resultMap="BaseResultMap">
        SELECT * FROM leave_request WHERE id = #{id}
    </select>

    <select id="selectByUserId" parameterType="Integer" resultMap="BaseResultMap">
        SELECT * FROM leave_request WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM leave_request ORDER BY create_time DESC
    </select>

    <select id="selectByStatus" parameterType="String" resultMap="BaseResultMap">
        SELECT * FROM leave_request WHERE status = #{status} ORDER BY create_time DESC
    </select>

</mapper>